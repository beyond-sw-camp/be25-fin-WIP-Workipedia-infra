OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENAI_API_KEY=change-me
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

QDRANT_HOST=<qdrant-ec2-private-ip-or-dns>
QDRANT_PORT=6333

TOOL_CLIENT=workipedia
BE_BASE_URL=http://<be-ec2-private-ip-or-dns>:8080
INTERNAL_API_KEY=change-me
