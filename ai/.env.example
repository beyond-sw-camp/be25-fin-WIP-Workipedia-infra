AI_IMAGE=ghcr.io/beyond-sw-camp/be25-fin-wip-workipedia-ai:<commit-sha>
AI_PORT=8000
TZ=Asia/Seoul

LLM_PROVIDER=openai
EMBEDDING_PROVIDER=local
RAG_RERANKER_ENABLED=false
RAG_RETRIEVAL_SCORE_THRESHOLD=0.50
CHAT_MODEL=llama3.1:8b
