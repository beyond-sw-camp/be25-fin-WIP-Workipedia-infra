BACKEND_IMAGE=ghcr.io/beyond-sw-camp/be25-fin-wip-workipedia-be:<commit-sha>
ELASTICSEARCH_IMAGE=ghcr.io/beyond-sw-camp/be25-fin-wip-workipedia-be-elasticsearch:8.18.8
BACKEND_PORT=8080
TZ=Asia/Seoul
SPRING_PROFILES_ACTIVE=local

MARIADB_HOST=workipedia-rds.xxxxxx.ap-northeast-2.rds.amazonaws.com
MARIADB_PORT=3306
MARIADB_DATABASE=workipedia
MARIADB_USER=wip
MARIADB_PASSWORD=change-me

REDIS_PASSWORD=change-me
JWT_SECRET=change-me
INTERNAL_API_KEY=change-me

STORAGE_PROVIDER=s3
AWS_REGION=ap-northeast-2
S3_UPLOAD_BUCKET=workipedia-upload-prod
AWS_ACCESS_KEY=change-me
AWS_SECRET_KEY=change-me

# 인프라 ESG 대시보드: 모니터링할 EC2 인스턴스 ID (CloudWatch CPU 조회 대상)
# AWS 자격증명/리전은 위 S3용(AWS_ACCESS_KEY/AWS_SECRET_KEY/AWS_REGION)을 재사용한다.
# 권한: cloudwatch:GetMetricStatistics, ec2:DescribeInstances, autoscaling:DescribeAutoScalingGroups 필요
INFRA_ESG_BE_INSTANCE_ID=i-xxxxxxxxxxxx
INFRA_ESG_AI_ASG_NAME=workipedia-ai-asg
INFRA_ESG_QDRANT_INSTANCE_ID=i-xxxxxxxxxxxx

AI_BASE_URL=http://<ai-asg-private-dns-or-alb>:8000

TOOL_ALLOWED_HOSTS=weather.workipedia.wiki
TOOL_DB_ALLOWED_DATASOURCES=
TOOL_DB_READONLY_URL=
TOOL_DB_READONLY_USERNAME=
TOOL_DB_READONLY_PASSWORD=
